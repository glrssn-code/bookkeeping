{
  "name": "bookkeeping",
  "version": "2.0.0",
  "description": "记账本 - 简单的记账应用程序",
  "author": "glrssn",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "package": "electron-builder --win --x64",
    "package:dir": "electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "antd": "^5.12.0",
    "echarts": "^5.4.3",
    "echarts-for-react": "^3.0.2",
    "idb": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.10"
  },
  "build": {
    "appId": "com.bookkeeping.app",
    "productName": "记账本",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "记账本_${version}.exe"
    }
  }
}
